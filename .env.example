# Environment Configuration for Development
AI_API_KEY=sk-your-openai-api-key-here
AI_PROVIDER=openai
AI_MODEL=gpt-4
MAX_TOKENS=2000
TEMPERATURE=0.7

# Database Configuration
SPRING_DATASOURCE_URL=jdbc:h2:mem:queryminddb
SPRING_DATASOURCE_USERNAME=sa
SPRING_DATASOURCE_PASSWORD=

# Server Configuration
SERVER_PORT=8080
SERVER_SERVLET_CONTEXT_PATH=/querymind

# Logging
LOGGING_LEVEL_COM_QUERYMIND=DEBUG
LOGGING_LEVEL_ROOT=INFO

